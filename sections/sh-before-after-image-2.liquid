  <style>
    #sh-{{ section.id }}.sh-compar-sec-2 {padding-top: {{section.settings.padding_top}}px; padding-bottom: {{ section.settings.padding_bottom }}px;background: {{section.settings.bg_color}};}
    #sh-{{ section.id }} .sh-page-width {max-width: {{section.settings.section_max_width}}px;width: 100%;padding: 0 20px;margin: 0 auto;}
