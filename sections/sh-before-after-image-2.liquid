    #sh-{{ section.id }} .sh-compar-sec-2-desc ul {padding-left: 20px;margin-top: 15px;display: inline-block;}
    #sh-{{ section.id }} .sh-compar-sec-2-desc ul li {list-style: square;font-size: {{ section.settings.content_font_size | minus: 1 }}px;line-height: 1.55;color: {{section.settings.content_color}};width: fit-content;} 
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button {margin: 25px 0 0;font-size: 16px;line-height: 1.65;background: {{section.settings.btn_bg_color}};color: {{section.settings.btn_text_color}};padding: 6px 20px;min-width: 140px;display: inline-block;border: 1px solid {{section.settings.btn_border_color}};border-radius: {{section.settings.border_radius}}px;text-align: center;cursor: pointer;max-width: fit-content;}
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button:hover {background: {{section.settings.btn_hover_bg_color}};color: {{section.settings.btn_hover_text_color}};border: 1px solid {{section.settings.btn_hover_border_color}};box-shadow: 0 0 5px 0px {{section.settings.outline_btn_shadow_color}};}
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button.sh-button-outline {color: {{section.settings.outline_btn_text_color}};border-color: {{section.settings.outline_btn_text_color}};background: transparent;}
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button svg {width: 20px;height: 20px;fill:{{section.settings.btn_text_color}};display: inline-block;vertical-align: text-bottom;margin-left: 5px;}
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button.sh-button-outline svg {fill:{{section.settings.outline_btn_text_color}};}
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button:hover svg {fill: {{section.settings.btn_hover_text_color}};}
    #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button svg path{fill: inherit;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container {flex: 0 0 50%;position: relative;overflow: hidden;border-radius: {{ section.settings.media_radius }}px;aspect-ratio: 1 / 1;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-compar-sec-2-small {aspect-ratio: 16 / 12;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-compar-sec-2-medium {aspect-ratio: 16 / 14;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-compar-sec-2-large {aspect-ratio: 16 / 16;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-wrap img {background: #fff;width: 100%;height: 100%;object-fit: cover;object-position: center;}
    #sh-{{ section.id }} .sh-compar-sec-2-wrapper {display: flex;flex-wrap: wrap;align-items: center;gap: 20px;}
    #sh-{{ section.id }} .sh-compar-sec-2-content {flex: 0 0 calc(50% - 20px);padding: 0 20px;}
    #sh-{{ section.id }} .sh-compar-sec-2-wrapper.sh-compar-sec-2-media-right{flex-direction: row-reverse;}
    #sh-{{ section.id }} .sh-compar-sec-2-content.sh-compar-sec-2-content-middle{align-self: center;}
    #sh-{{ section.id }} .sh-compar-sec-2-content.sh-compar-sec-2-content-top{align-self: flex-start;}
    #sh-{{ section.id }} .sh-compar-sec-2-content.sh-compar-sec-2-content-bottom{align-self: flex-end;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-wrap.sh-before{clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);}
    #sh-{{ section.id }} .sh-compar-sec-2-img-wrap{width: 100%;height: 100%;position: absolute;}
    #sh-{{ section.id }} .sh-compar-sec-2-slide:focus {outline: unset !important;outline-offset: unset !important;}
    #sh-{{ section.id }} .sh-compar-sec-2-line {position: absolute;left: 50%;transform: translateX(-50%);width: 2px;height: 100%;background-color: {{section.settings.sep_bg_color }};top: 0;z-index: 1;}
    /* Starting point */
    #sh-{{ section.id }} .sh-compar-sec-2-img-wrap .sh-before {clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);}
    #sh-{{ section.id }} .sh-compar-sec-2-slide[type=range] {position: relative;-webkit-appearance: none;width: calc(100% + 40px);height: 100%;margin:0;margin-left: -20px;background-color: transparent;outline: none;max-width: unset;border: unset;padding:0;z-index: 2;}
    /* WebKit/Blink */
    #sh-{{ section.id }} .sh-compar-sec-2-slide[type=range]::-webkit-slider-thumb{-webkit-appearance: none;appearance: none;height: 40px;width: 40px;border-radius: 50%;box-shadow: 0px 0px 8px 2px rgba(0,0,0,0.1);background-color: #fff;background-size: cover;cursor: ew-resize;background-image: url('data:image/svg+xml, <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="25" cy="25" r="25" fill="{{ section.settings.sep_bg_color | replace: '#', '%23' }}"></circle><path d="M20.5 32L14 25.5L20.5 19" stroke="{{ section.settings.sep_arrow_color | replace: '#', '%23' }}" stroke-width="1.5"></path><path d="M30.5 32L37 25.5L30.5 19" stroke="{{ section.settings.sep_arrow_color | replace: '#', '%23' }}" stroke-width="1.5"></path></svg>');}
    /* Firefox */
    #sh-{{ section.id }} .sh-compar-sec-2-slide[type=range]::-moz-range-thumb{-webkit-appearance: none;appearance: none;height: 40px;width: 40px;border-radius: 50%;box-shadow: 0px 0px 8px 2px rgba(0,0,0,0.1);background-color: #fff;background-size: cover;cursor: ew-resize;background-image: url('data:image/svg+xml, <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="25" cy="25" r="25" fill="{{ section.settings.sep_bg_color | replace: '#', '%23' }}"></circle><path d="M20.5 32L14 25.5L20.5 19" stroke="{{ section.settings.sep_arrow_color | replace: '#', '%23' }}" stroke-width="1.5"></path><path d="M30.5 32L37 25.5L30.5 19" stroke="{{ section.settings.sep_arrow_color | replace: '#', '%23' }}" stroke-width="1.5"></path></svg>');}
    /* IE */
    #sh-{{ section.id }} .sh-compar-sec-2-slide[type=range]::-ms-thumb {-webkit-appearance: none;appearance: none;height: 40px;width: 40px;border-radius: 50%;box-shadow: 0px 0px 8px 2px rgba(0,0,0,0.1);background-color: #fff;background-size: cover;cursor: ew-resize;background-image: url('data:image/svg+xml, <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="25" cy="25" r="25" fill="{{ section.settings.sep_bg_color | replace: '#', '%23' }}"></circle><path d="M20.5 32L14 25.5L20.5 19" stroke="{{ section.settings.sep_arrow_color | replace: '#', '%23' }}" stroke-width="1.5"></path><path d="M30.5 32L37 25.5L30.5 19" stroke="{{ section.settings.sep_arrow_color | replace: '#', '%23' }}" stroke-width="1.5"></path></svg>');}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container .sh-compar-sec-2-img-wrap:after {position: absolute;color: {{section.settings.ba_button_text_color}};font-size: {{ section.settings.text_font_size }}px;z-index: 0;background-color: {{section.settings.ba_button_bg_color}};max-width: calc(50% - 20px);line-height: 1.2;padding: 5px 15px;border-radius: {{ section.settings.media_radius }}px;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container .sh-compar-sec-2-img-wrap.sh-after:after {content: "{{section.settings.after_text}}";}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container .sh-compar-sec-2-img-wrap.sh-before:after {content: "{{section.settings.before_text}}";}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-after-before-txt-top .sh-compar-sec-2-img-wrap.sh-after:after {top: 10px;right: 10px;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-after-before-txt-bottom .sh-compar-sec-2-img-wrap.sh-after:after {bottom: 10px;right: 10px;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-after-before-txt-middle .sh-compar-sec-2-img-wrap.sh-after:after {right: 10px;top: 50%;transform: translateY(-50%);}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-after-before-txt-top .sh-compar-sec-2-img-wrap.sh-before:after {top: 10px;left: 10px;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-after-before-txt-bottom .sh-compar-sec-2-img-wrap.sh-before:after {bottom: 10px;left: 10px;}
    #sh-{{ section.id }} .sh-compar-sec-2-img-container.sh-after-before-txt-middle .sh-compar-sec-2-img-wrap.sh-before:after {left: 10px;top: 50%;transform: translateY(-50%);}
    @media only screen and (max-width: 767px){
      #sh-{{ section.id }} .sh-compar-sec-2-content {flex: auto;padding: 0;}
      #sh-{{ section.id }} .sh-compar-sec-2-img-container{flex: auto;}
      #sh-{{ section.id }} .sh-compar-sec-2-title{font-size: 26px;}
      #sh-{{ section.id }} .sh-compar-sec-2-desc ul {margin-top: 10px;}
      #sh-{{ section.id }} .sh-compar-sec-2-desc ul li{font-size: 13.5px;}
      #sh-{{ section.id }} .sh-compar-sec-2-desc{margin:15px 0 0;} 
      #sh-{{ section.id }} .sh-compar-sec-2-desc p{font-size: 14px;} 
      #sh-{{ section.id }} .sh-compar-sec-2-content .sh-button{font-size: 15px;margin:15px 0 0;} 
