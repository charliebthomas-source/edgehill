        },
        "text_maker": {
          "type": "text",
          "settings": {
            "text": "<p>Hi, I\u2019m Charlie \u2014 every item you see here is made, restored or finished by me, by hand. Whether I\u2019m weaving a cane chair seat, knitting a beanie, or printing a lithophane on my 3D printer, the same principle applies: do it properly or don\u2019t do it at all.</p><p>If you have a question, want to discuss a custom order, or need a quote for a chair, email me directly: Charliebthomas@icloud.com. You\u2019ll get a reply from me, not a bot.</p>",
            "text_style": "body"
