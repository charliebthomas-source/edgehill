    "multirow_tK6Xqt": {
      "type": "multirow",
      "blocks": {
        "row_W7XtTJ": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/50B79282-B000-47C0-8E8E-33F13E84A9C8.jpg",
            "caption": "Traditional Craft \u00b7 Restored by Hand \u00b7 From \u00a330",
            "heading": "Cane Chair Restoration",
            "text": "<p>Got a cherished chair with a sagging or broken cane seat? It can be saved. Using traditional hand-weaving techniques, each seat is recaned strand by strand \u2014 restoring it to its original strength and appearance without replacing the chair.</p><p>Heirloom dining chairs, Victorian nursing chairs, vintage market finds \u2014 if the frame is sound, the seat can be restored. A proper repair lasts decades. Free quotes via email with no obligation.</p>",
            "button_label": "Request a Free Quote",
            "button_link": "shopify://pages/cane"
          }
        },
        "row_R8ag74": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/DSC01112.jpg",
            "caption": "Handknitted in the UK \u00b7 Reversible \u00b7 From \u00a315",
            "heading": "Handmade Wooly Beanies",
            "text": "<p>Warm, cosy, and genuinely handmade \u2014 every beanie is knitted using premium wool blends, one at a time. Reversible designs give you two colourways in a single hat, and each one is made to last rather than fall apart after a season.</p><p>A practical gift that actually feels considered. From \u00a315.</p>",
            "button_label": "Shop Beanies",
            "button_link": "shopify://pages/beanies"
          }
        },
        "row_AkxGCy": {
          "type": "row",
          "settings": {
            "image": "shopify://shop_images/IMG_5883.jpg",
            "caption": "3D Printed \u00b7 Personalised \u00b7 From \u00a312",
            "heading": "Custom Lithophane Prints",
            "text": "<p>A lithophane is a 3D-printed tile that reveals your photograph in glowing detail when held up to the light. What looks like a plain white panel transforms into a portrait, landscape, or memory \u2014 it has to be seen to be believed. From \u00a312.</p>",
            "button_label": "Create Yours",
            "button_link": "shopify://pages/custom-lithophane"
          }
        }
      },
